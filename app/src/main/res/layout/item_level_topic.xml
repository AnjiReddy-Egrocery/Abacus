<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:background="@drawable/bg_level_item"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        card_view:cardCornerRadius="12dp"
        card_view:cardElevation="6dp"
        android:id="@+id/cardView"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_course_typelevel"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <!-- Course Image -->

                <!-- 2-Row Level Boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:id="@+id/layout_level"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvcoursename"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:text=""
                        android:textStyle="bold"
                        android:textSize="16dp"
                        android:textColor="#000000" />

                    <LinearLayout
                        android:id="@+id/layout_buttons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:layout_marginBottom="5dp"
                        android:layout_marginTop="8dp">

                        <Button
                            android:id="@+id/btnPractice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PracticeKnow"
                            android:backgroundTint="#ff6600"
                            android:textSize="12sp"/>

                        <Button
                            android:id="@+id/btnVisualization"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Visualization"
                            android:backgroundTint="#198754"
                            android:textSize="12sp"/>

                        <Button
                            android:id="@+id/btnView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="ViewPractice"
                            android:backgroundTint="#8F8A8A"
                            android:textSize="12sp"/>




                    </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
