<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:background="#fff"
    tools:context=".Activity.ViewPracticeListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#4e148c">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:id="@+id/layout_back"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:background="@drawable/circle_image">

                        <ImageView
                            android:layout_width="8dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="12dp"
                            android:src="@drawable/baseline_arrow_back_ios_new_24" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="12dp"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allocated Courses"
                            android:fontFamily="@font/regular"
                            android:textStyle="bold"
                            android:textColor="#fff"
                            android:textSize="14dp"

                            android:id="@+id/txt_topic_name"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/recycler_course_type"/>

            <TextView
                android:id="@+id/txtNoCourses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No Courses Allocated"
                android:textColor="#FF0000"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="30dp"
                android:visibility="gone"/>

        </LinearLayout>



    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>