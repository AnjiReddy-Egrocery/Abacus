<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    android:background="@drawable/signin_background">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layout_header_signin"
            android:visibility="visible"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:orientation="vertical"
                android:background="@drawable/circle_image">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:src="@drawable/baseline_arrow_back_ios_new_24"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="OTP Verification"
                android:textStyle="bold"
                android:textSize="25dp"
                android:gravity="center_vertical"
                android:textColor="#FFF"
                android:layout_marginLeft="16dp"/>

        </LinearLayout>



    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp"
        android:background="@drawable/layout_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:id="@+id/layout_form_otp_verification">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter OTP"
                        android:textSize="20dp"
                        android:textColor="#000"
                        android:textStyle="bold" />
                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Enter otp"
                        android:inputType="textAutoComplete"
                        android:paddingLeft="12dp"
                        android:layout_marginTop="6dp"
                        android:paddingRight="14dp"
                        android:id="@+id/edt_otp"
                        android:background="@drawable/back_ground"
                        android:textColorHint="#000" />

                    <TextView
                        android:id="@+id/txt_otp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Please Enter OTP"
                        android:layout_marginTop="6dp"
                        android:layout_marginLeft="4dp"
                        android:textColor="#D80B0B"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="20dp"
                        android:layout_marginTop="14dp"
                        android:textColor="#000"
                        android:textStyle="bold" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="PassWord"
                        android:inputType="textAutoComplete"
                        android:paddingLeft="12dp"
                        android:layout_marginTop="6dp"
                        android:id="@+id/password"
                        android:paddingRight="14dp"
                        android:background="@drawable/back_ground"
                        android:textColorHint="#000" />

                    <TextView
                        android:id="@+id/txt_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Please Enter Password"
                        android:layout_marginTop="6dp"
                        android:layout_marginLeft="4dp"
                        android:textColor="#D80B0B"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=" Confirm Password"
                        android:textSize="20dp"
                        android:layout_marginTop="14dp"
                        android:textColor="#000"
                        android:textStyle="bold" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Confirm PassWord"
                        android:inputType="textAutoComplete"
                        android:paddingLeft="12dp"
                        android:layout_marginTop="6dp"
                        android:id="@+id/edt_reenter_password"
                        android:paddingRight="14dp"
                        android:background="@drawable/back_ground"
                        android:textColorHint="#000" />
                    <TextView
                        android:id="@+id/txt_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Please Enter Confirm Password"
                        android:layout_marginTop="6dp"
                        android:layout_marginLeft="4dp"
                        android:textColor="#D80B0B"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    <Button
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Verify account"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#FFF"
        android:id="@+id/but_verify"
        android:visibility="visible"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#FD6801"/>
</LinearLayout>